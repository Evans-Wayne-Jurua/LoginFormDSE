<Page
    x:Class="LoginForm.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LoginForm"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/airplane.jpg"/>
        </Grid.Background>

        <StackPanel Orientation="Vertical" Margin="200" Background="#80FFFFFF" Width="300" Height="300" CornerRadius="20">
                <TextBlock Text="LOGIN" HorizontalAlignment="Center" Margin="10" FontWeight="Bold" FontSize="25"/>
            <TextBox x:Name="UsernameBox" CornerRadius="5" PlaceholderText="Username"
                         Header="Username:"
                         Width="170" Margin="10"/>
            <PasswordBox Width="170" Header="Password:" x:Name="PasswordBox" CornerRadius="5" PlaceholderText="Password"/>

            <Button HorizontalAlignment="Center" Width="100" CornerRadius="5" Background="LightCyan" Content="Submit" Click="Button_Click" Margin="10"/>
        </StackPanel>

        

    </Grid>
</Page>
